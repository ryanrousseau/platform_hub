name = "Smoke test service"
description = ""

icon {
    color = "#D63D3D"
    id = "fire-alt"
}

parameter "template.account" {
    display_settings = {
        Octopus.ControlType = "UsernamePasswordAccount"
    }
    help_text = ""
    label = "Account Param"

    value "vault-credentials" {}
}

parameter "tmp.workerpool" {
    display_settings = {
        Octopus.ControlType = "WorkerPool"
    }
    help_text = ""
    label = "Worker pool"
}

step "run-a-script" {
    name = "Run a Script"

    action {
        action_type = "Octopus.Script"
        properties = {
            Octopus.Action.RunOnServer = "true"
            Octopus.Action.Script.ScriptBody = <<-EOT
                usern=$(get_octopusvariable "ProcessTemplates[test].template.account.Username")
                passwo=$(get_octopusvariable "ProcessTemplates[test].template.account.Password")
                echo "User name: $usern"
                echo "Password: $passwo"
                
                echo "Direct: #{ProcessTemplates[test].template.account.Username}"
                EOT
            Octopus.Action.Script.ScriptSource = "Inline"
            Octopus.Action.Script.Syntax = "Bash"
            OctopusUseBundledTooling = "False"
        }
        worker_pool_variable = "#{tmp.workerpool}"
    }
}